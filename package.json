{
  "name": "iraqi-labor-scheduler",
  "private": true,
  "version": "4.1.0",
  "description": "Workforce scheduler tailored for Iraqi Labor Law (Art. 67-74, 88). Dual-mode: offline-first single-user OR Firebase-backed multi-user with role-based access and full in-app management.",
  "author": {
    "name": "Iraqi Labor Scheduler Project",
    "email": "assassinmachete@gmail.com",
    "url": "https://github.com/assassinoa93/iraqi-labor-scheduler"
  },
  "homepage": "https://github.com/assassinoa93/iraqi-labor-scheduler",
  "license": "Apache-2.0",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:server": "node scripts/build-server.cjs",
    "icons": "node scripts/build-icon.cjs",
    "bootstrap-super-admin": "node scripts/bootstrap-super-admin.cjs",
    "migrate-to-firestore": "node scripts/migrate-to-firestore.cjs",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://127.0.0.1:3000 && electron .\"",
    "electron:build": "npm run lint && npm run icons && npm run build && npm run build:server && electron-builder"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-kufi-arabic": "^5.2.9",
    "@fontsource/noto-naskh-arabic": "^5.2.11",
    "@fontsource/outfit": "^5.2.8",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react-window": "^1.8.8",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "date-fns": "^3.6.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "firebase": "^11.0.0",
    "firebase-admin": "^13.8.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^0.378.0",
    "motion": "^11.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^2.2.7",
    "tailwind-merge": "^2.3.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.4.2",
    "wait-on": "^7.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.20.2",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tsx": "^4.10.2",
    "typescript": "^5.2.2",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "com.iraqi.labor.scheduler",
    "productName": "Iraqi Labor Scheduler",
    "copyright": "Copyright © 2026 Iraqi Labor Scheduler Project. Apache-2.0 licensed.",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server-bundle.cjs",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "publisherName": "Iraqi Labor Scheduler Project",
      "legalTrademarks": "Iraqi Labor Scheduler",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Iraqi Labor Scheduler",
      "uninstallDisplayName": "Iraqi Labor Scheduler",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "displayLanguageSelector": false,
      "differentialPackage": false,
      "include": "build/installer.nsh"
    }
  }
}
